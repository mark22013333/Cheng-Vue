# CoolApps 環境變數範本
# 
# 使用說明：
# 1. 複製此檔案為 .env：cp .env.example .env
# 2. 填入實際的配置值（聯繫管理員取得）
# 3. 確保 .env 檔案不要提交到 Git（已在 .gitignore 中）

# ==================================================
# Jasypt 加密密碼（必填）
# ==================================================
# 用途：解密 application.yml 中的 ENC() 加密配置
# 取得方式：聯繫專案負責人或查看內部文檔
JASYPT_PASSWORD=

# ==================================================
# 應用程式環境（必填）
# ==================================================
# 選項：local（本地開發）、dev（開發環境）、prod（生產環境）
SPRING_PROFILES_ACTIVE=local

# ==================================================
# 伺服器配置
# ==================================================
# 後端服務埠號（預設：8080）
PORT=8080

# 時區設定（預設：Asia/Taipei）
TZ=Asia/Taipei

# ==================================================
# 檔案上傳路徑
# ==================================================
# 本地開發範例：/Users/cheng/uploadPath
# 生產環境範例：/opt/cool-apps/upload
UPLOAD_PATH=

# ==================================================
# LINE Bot 設定（選填，如有使用 LINE 功能）
# ==================================================
# LINE Channel Secret（聯繫管理員取得）
LINE_CHANNEL_SECRET=

# LINE Channel Access Token（聯繫管理員取得）
LINE_CHANNEL_ACCESS_TOKEN=

# ==================================================
# 資料庫配置（選填，已在 application.yml 中加密）
# ==================================================
# 如需覆寫，可在此設定（不建議）
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=cool-apps
# DB_USERNAME=
# DB_PASSWORD=

# ==================================================
# Redis 配置（選填，已在 application.yml 中設定）
# ==================================================
# 如需覆寫，可在此設定
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DATABASE=0
